# =========================
# PostgreSQL
# =========================
POSTGRES_DB=biblioteca
POSTGRES_USER=biblioteca_app
POSTGRES_PASSWORD=cambiar_en_local
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# =========================
# Servicio Biblioteca (Spring Boot)
# =========================
SERVICIO_BIBLIOTECA_PUERTO=8080
SERVICIO_BIBLIOTECA_PERFIL=docker

# =========================
# Servicio Prestamos (Go)
# =========================
SERVICIO_PRESTAMOS_PUERTO_HTTP=8081
SERVICIO_PRESTAMOS_PUERTO_GRPC=9090
SERVICIO_PRESTAMOS_URL_BASE=http://servicio-prestamos:8081

# =========================
# Comunicación inter-servicios
# =========================
SERVICIO_BIBLIOTECA_URL_BASE=http://servicio-biblioteca:8080
HTTP_CLIENTE_TIMEOUT_CONEXION_MS=2000
HTTP_CLIENTE_TIMEOUT_LECTURA_MS=5000

# =========================
# Seguridad JWT
# =========================
JWT_CLAVE_SECRETA=reemplazar_por_clave_HS256_de_minimo_32_bytes
JWT_DURACION_ACCESO_MINUTOS=15
JWT_DURACION_REFRESCO_DIAS=7
JWT_EMISOR=mariposa-biblioteca

# =========================
# Observabilidad
# =========================
NIVEL_LOG_ROOT=INFO
NIVEL_LOG_APLICACION=DEBUG
