# =========================
# PostgreSQL
# =========================
POSTGRES_DB=biblioteca
POSTGRES_USER=biblioteca_app
POSTGRES_PASSWORD=cambiar_en_local
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# =========================
# Servicio Biblioteca (Spring Boot)
# =========================
SERVICIO_BIBLIOTECA_PUERTO=8080
SERVICIO_BIBLIOTECA_PERFIL=docker

# =========================
# Servicio Prestamos (Go)
# =========================
SERVICIO_PRESTAMOS_PUERTO=8081
SERVICIO_PRESTAMOS_URL_BASE=http://servicio-prestamos:8081

# PostgreSQL dedicado del Servicio Prestamos
POSTGRES_PRESTAMOS_DB=prestamos
POSTGRES_PRESTAMOS_USER=prestamos_app
POSTGRES_PRESTAMOS_PASSWORD=cambiar_en_local
POSTGRES_PRESTAMOS_HOST=postgres-prestamos
POSTGRES_PRESTAMOS_PORT=5433

# =========================
# Comunicación inter-servicios
# =========================
SERVICIO_BIBLIOTECA_URL_BASE=http://servicio-biblioteca:8080
HTTP_CLIENTE_TIMEOUT_CONEXION_MS=2000
HTTP_CLIENTE_TIMEOUT_LECTURA_MS=5000
HTTP_CLIENTE_TIMEOUT_SEGUNDOS=5

# Secreto compartido para el header X-Servicio-Interno usado por el
# Servicio Prestamos al llamar al endpoint interno del Servicio Biblioteca.
SERVICIO_INTERNO_SECRETO=secreto-compartido-mariposa-cambiar-en-produccion

# =========================
# Seguridad JWT
# =========================
JWT_CLAVE_SECRETA=reemplazar_por_clave_HS256_de_minimo_32_bytes
JWT_DURACION_ACCESO_MINUTOS=15
JWT_DURACION_REFRESCO_DIAS=7
JWT_EMISOR=mariposa-biblioteca

# =========================
# Rate limiting (POST /api/v1/autenticacion/iniciar-sesion)
# =========================
# Token bucket en memoria por IP del cliente (con soporte X-Forwarded-For).
# Mitigacion contra fuerza bruta.
LIMITE_TASA_INICIO_SESION_HABILITADO=true
LIMITE_TASA_INICIO_SESION_CAPACIDAD=5
LIMITE_TASA_INICIO_SESION_VENTANA_SEGUNDOS=60

# =========================
# Observabilidad
# =========================
NIVEL_LOG_ROOT=INFO
NIVEL_LOG_APLICACION=DEBUG
